Table Transfer_Payment_Profile {
  _deleted boolean [not null, default: false]
  id bigserial [pk, not null] // System ID
  egcs_tp_agency bigint [not null]
  egcs_tp_dateend date [not null] // Effective end date of the TP Program.
  egcs_tp_datestart date [not null] // Effective start date of the TP Program
  egcs_tp_description_en text [not null] // Description of the TP program.
  egcs_tp_description_fr text [not null] // Description of the TP program.
  egcs_tp_name_en varchar(255) [not null] // English name of the TP program.
  egcs_tp_name_fr varchar(255) [not null] // French name of the TP program.
  egcs_tp_abbreviation_en varchar(255) [not null] // Short name to quickly identify the TP program.
  egcs_tp_abbreviation_fr varchar(255) [not null] // Short name to quickly identify the TP program.
  egcs_tp_tclink varchar(2000) [not null] // Link to the Terms & Conditions of the TP program.
  egcs_tp_purpose_en text [not null] // The program purpose is the program’s purpose according to the Ts&Cs.
  egcs_tp_purpose_fr text [not null] // The program purpose is the program’s purpose according to the Ts&Cs.
  egcs_tp_status Base_Status [not null]

  Indexes {
    egcs_tp_name_en [name: 'tp_idx_profilenameen', where: `_deleted = false AND egcs_tp_status = 'active'`]
    egcs_tp_name_fr [name: 'tp_idx_profilenamefr', where: `_deleted = false AND egcs_tp_status = 'active'`]
    (egcs_tp_agency, egcs_tp_name_en, egcs_tp_name_fr, egcs_tp_status) [name: 'tp_idx_profileagencynameennamefrstatus', unique, where: `_deleted = false AND egcs_tp_status = 'active'`]
  }

  checks {
    `egcs_tp_dateend >= egcs_tp_datestart` [name: 'tp_chk_profiledatestartdateend']
  }
}
Ref: Transfer_Payment_Profile.egcs_tp_agency > Agency_Profile.id

Table Transfer_Payment_Fiscal_Year_Budget {
  _deleted boolean [not null, default: false]
