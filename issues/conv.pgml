  egcs_ay_fiscalyear smallint [not null] // Numerical value for fiscal year, e.g. 2026

  Indexes {
    (egcs_ay_organizationagency, egcs_ay_fiscalyeardisplay) [name: 'ay_idx_fiscalyearorganizationagencyfiscalyeardisplay', unique, where: `_deleted = false`]
