Table Common_Recommendation_Setup {
  _deleted boolean [not null, default: false]
  id bigserial [pk, not null] // System ID
  egcs_cn_scopetype Entity_Type [not null] // fundingopportunity | transferpaymentstream | fundingcaseintake | fundingcaseagreement | applicantrecipient
  egcs_cn_scopeid bigint [not null] // Which specific TP Stream or FO owns this config
  egcs_cn_entitytype Entity_Type [not null] // What completion event triggers set creation
  egcs_cn_name_en varchar(255) [not null]
  egcs_cn_name_fr varchar(255) [not null]
  egcs_cn_description_en text [not null]
  egcs_cn_description_fr text [not null]
  egcs_cn_schema bigint [not null]
  egcs_cn_approvaltemplate bigint
  egcs_cn_active boolean [not null]

  Indexes {
    (egcs_cn_scopeid, egcs_cn_entitytype) [name: 'cn_idx_recommendationsetupscopeidentitytype', unique, where: `_deleted = false AND egcs_cn_active = TRUE`]
    (id, egcs_cn_entitytype) [name: 'cn_idx_recommendationsetupidentitytype', unique]
  }

  checks {
    `egcs_cn_scopetype IN ('fundingopportunity', 'transferpaymentstream', 'fundingcaseintake', 'fundingcaseagreement', 'applicantrecipient')` [name: 'cn_chk_recommendationsetupscopetype']
    `egcs_cn_entitytype NOT IN ('fundingopportunity', 'transferpaymentstream', 'fundingcaseintake', 'fundingcaseagreement', 'applicantrecipient', 'commonrecommendation')` [name: 'cn_chk_recommendationsetupentitytype']
  }
}
Ref: Common_Recommendation_Setup.egcs_cn_schema > Common_Recommendation_Schema.id
Ref: Common_Recommendation_Setup.egcs_cn_approvaltemplate > Common_Approval_Template.id
Ref cn_ref_recommendationsetupscopeidscopetype: Common_Recommendation_Setup.(egcs_cn_scopeid, egcs_cn_scopetype) > Common_Entity.(id, egcs_cn_entitytype)

Table Common_Recommendation {
  _deleted boolean [not null, default: false]
  id bigserial [pk, not null] // System ID
  egcs_cn_recommendationsetup bigint [not null]
  egcs_cn_entitytype Entity_Type [not null]
  egcs_cn_entityid bigint [not null]
  egcs_cn_recommendation smallint
  egcs_cn_response jsonb [not null] // Who and when are captured by completion

  Indexes {
    (egcs_cn_entitytype, egcs_cn_entityid) [name: 'cn_idx_recommendationentitytypeentityid', unique, where: `_deleted = false`]
  }
}
Ref cn_ref_recommendationentityidentitytype: Common_Recommendation.(egcs_cn_entityid, egcs_cn_entitytype) > Common_Entity.(id, egcs_cn_entitytype)
Ref cn_ref_recommendationrecommendationsetupentitytype: Common_Recommendation.(egcs_cn_recommendationsetup, egcs_cn_entitytype) > Common_Recommendation_Setup.(id, egcs_cn_entitytype)

