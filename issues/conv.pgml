Table Agency_Profile {
  _deleted boolean [not null, default: false]
  id bigserial [pk, not null] // System ID
  egcs_ay_gwcoa_number bigint [not null] // Linkage to the Government Wide Chart of Accounts Department/Agency Number
  egcs_ay_agencyfinancialsystemid bigint [not null] // ID of the federal institution
  egcs_ay_name_en varchar(255) [not null] // Name of the federal institution in english
  egcs_ay_name_fr varchar(255) [not null] // Name of the federal institution in french
  egcs_ay_abbreviation_en varchar(255) [not null] // abbreviation representing the federal institution in english
  egcs_ay_abbreviation_fr varchar(255) [not null] // abbreviation representing the federal institution in french
  egcs_ay_status Base_Status [not null] // Status for the federal institution

  Indexes {
    egcs_ay_name_en [name: 'ay_idx_profilenameen', where: `_deleted = false`]
    egcs_ay_name_fr [name: 'ay_idx_profilenamefr', where: `_deleted = false`]
    (egcs_ay_agencyfinancialsystemid, egcs_ay_name_en, egcs_ay_name_fr, egcs_ay_status) [name: 'ay_idx_profileagencyfinancialsystemidnameennamefrstatus', unique, where: `_deleted = false`]
  }
}
Ref: Agency_Profile.egcs_ay_gwcoa_number > Common_GWCOA.egcs_cn_number

Table Agency_Cost_Category {
  _deleted boolean [not null, default: false]
  id bigserial [pk, not null] // System ID
  egcs_ay_organizationagency bigint [not null]
  egcs_ay_name_en varchar(255) [not null] // Cost categories available to the transfer payment programs under this federal institution (english)
  egcs_ay_name_fr varchar(255) [not null] // Cost categories available to the transfer payment programs under this federal institution (french)

  Indexes {
    (egcs_ay_organizationagency, egcs_ay_name_en) [name: 'ay_idx_costcategoryorganizationagencynameen', unique, where: `_deleted = false`]
    (egcs_ay_organizationagency, egcs_ay_name_fr) [name: 'ay_idx_costcategoryorganizationagencynamefr', unique, where: `_deleted = false`]
  }
}
Ref: Agency_Cost_Category.egcs_ay_organizationagency > Agency_Profile.id

