Table Common_Address {
  _deleted boolean [not null, default: false]
  id bigserial [pk, not null] // System ID
  egcs_cn_federalridingid integer [not null] // Federal riding ID based on geo-location data or manually captured
  egcs_cn_addresscity varchar(255) [not null] // City associated to the Account's address.
  egcs_cn_addresscountry Countries [not null] // Country associated to the Account's address.
  egcs_cn_addresssubdivision varchar(255) [not null] // Enum, Jurisdiction if country is CA, otherwise varchar
  egcs_cn_gc_addressid bigint [not null] // Unique identifier for entity instances
  egcs_cn_latitude numeric(10,7) // Latitude coordinate associated to the an address.
  egcs_cn_longitude numeric(10,7) // Longitude coordinate associated to the an address.
  egcs_cn_mainphone bigint [not null] // Primary telephone associated to the Account's address.
  egcs_cn_mainphoneextension smallint // Telephone extension associated to the Account's main telephone number.
  egcs_cn_postalcodezipcode varchar(255) [not null] // Postal code associated to the Account's address.
  egcs_cn_street1 varchar(255) [not null] // Line 1 of the street associated to the Account's address.
  egcs_cn_street2 varchar(255) // Line 2 of the street associated to the Account's address.
  egcs_cn_street3 varchar(255) // Line 3 of the street associated to the Account's address.

  checks {
