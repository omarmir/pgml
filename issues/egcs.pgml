    Ref: public.common_recommendation_schema.egcs_cn_agency > public.agency_profile.id

    Table public.common_recommendation_setup {
      _deleted boolean [not null, default: false]
      id bigint [pk, not null, default: nextval('public.Common_Recommendation_Setup_id_seq')] // System ID
      egcs_cn_scopetype public.entity_type [not null] // fundingopportunity | transferpaymentstream | fundingcaseintake | fundingcaseagreement | applicantrecipient
      egcs_cn_scopeid bigint [not null] // Which specific TP Stream or FO owns this config
