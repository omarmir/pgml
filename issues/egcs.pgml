    Table public.applicant_recipient_profile {
      _deleted boolean [not null, default: false]
      id bigint [pk, not null] /*
    PK sourced from Common_Entity via trigger on insert.
    See: trg_register_applicantrecipient
      */
      egcs_ar_provincialbusinessnumber integer // The official business number of the applicant/recipient provided by the province.
      egcs_ar_businessnumber bigint // A Canadian Business Number (BN) is a unique 9-digit identifier from the Canada Revenue Agency (CRA)
      egcs_ar_charitynumber bigint // Official charity registration number.
      egcs_ar_naics integer [not null] // NAICS code
      egcs_ar_description_en text // Description of the applicant/recipient (english).
      egcs_ar_description_fr text // Description of the applicant/recipient (french).
      egcs_ar_operatingname_en varchar(255) // This field should be populated when an organization operates under a name that differs from its legal name or business number. This field is not intended to capture the ultimate recipient of a grant or contribution; instead, the name of the person receiving funding from the Government of Canada should be entered.
      egcs_ar_operatingname_fr varchar(255) // This field should be populated when an organization operates under a name that differs from its legal name or business number. This field is not intended to capture the ultimate recipient of a grant or contribution; instead, the name of the person receiving funding from the Government of Canada should be entered.
      egcs_ar_applicantrecipientsubtypes bigint [not null]
      egcs_ar_leadagency bigint // For multi-dept systems, this is the id of the agency
      egcs_ar_legalname_en varchar(255) // Legal name of the applicant/recipient (English).
      egcs_ar_legalname_fr varchar(255) // Legal name of the applicant/recipient (French).
      egcs_ar_researchorganization_en varchar(255)
      egcs_ar_researchorganization_fr varchar(255)
      egcs_ar_status public.base_status [not null]

      indexes {
        egcs_ar_businessnumber [name: 'ar_idx_profilebusinessnumber', unique, where: `_deleted = false AND egcs_ar_businessnumber IS NOT NULL`]
      }
    }
