        (egcs_cn_agency, egcs_cn_entitytype, egcs_cn_name_fr) [name: 'cn_idx_recommendationschemaagencyentitytypenamefr', unique, where: `_deleted = false`]
      }

      checks {
        `egcs_cn_entitytype <> 'commonrecommendation'` [name: 'cn_chk_recommendationschemaentitytype']
      }
