    Table public.agency_profile {
      _deleted boolean [not null, default: false]
      id bigint [pk, not null, default: nextval('public.Agency_Profile_id_seq')] // System ID
      egcs_ay_gwcoa_number bigint [not null] // Linkage to the Government Wide Chart of Accounts Department/Agency Number
      egcs_ay_agencyfinancialsystemid bigint [not null] // ID of the federal institution
      egcs_ay_name_en varchar(255) [not null] // Name of the federal institution in english
      egcs_ay_name_fr varchar(255) [not null] // Name of the federal institution in french
      egcs_ay_abbreviation_en varchar(255) [not null] // abbreviation representing the federal institution in english
      egcs_ay_abbreviation_fr varchar(255) [not null] // abbreviation representing the federal institution in french
      egcs_ay_status public.base_status [not null] // Status for the federal institution

      indexes {
        egcs_ay_name_en [name: 'ay_idx_profilenameen', where: `_deleted = false`]
        egcs_ay_name_fr [name: 'ay_idx_profilenamefr', where: `_deleted = false`]
        (egcs_ay_agencyfinancialsystemid, egcs_ay_name_en, egcs_ay_name_fr, egcs_ay_status) [name: 'ay_idx_profileagencyfinancialsystemidnameennamefrstatus', unique, where: `_deleted = false`]
      }
    }
    Ref: public.agency_profile.egcs_ay_gwcoa_number > public.common_gwcoa.egcs_cn_number

    Table public.agency_cost_category {
      _deleted boolean [not null, default: false]
      id bigint [pk, not null, default: nextval('public.Agency_Cost_Category_id_seq')] // System ID
      egcs_ay_organizationagency bigint [not null]
      egcs_ay_name_en varchar(255) [not null] // Cost categories available to the transfer payment programs under this federal institution (english)
      egcs_ay_name_fr varchar(255) [not null] // Cost categories available to the transfer payment programs under this federal institution (french)

      indexes {
        (egcs_ay_organizationagency, egcs_ay_name_en) [name: 'ay_idx_costcategoryorganizationagencynameen', unique, where: `_deleted = false`]
        (egcs_ay_organizationagency, egcs_ay_name_fr) [name: 'ay_idx_costcategoryorganizationagencynamefr', unique, where: `_deleted = false`]
      }
    }
    Ref: public.agency_cost_category.egcs_ay_organizationagency > public.agency_profile.id

    Table public.agency_cost_category_line_item {
      _deleted boolean [not null, default: false]
      id bigint [pk, not null, default: nextval('public.Agency_Cost_Category_Line_Item_id_seq')] // System ID
      egcs_ay_name_en varchar(255) [not null] // Budget line items in english
      egcs_ay_name_fr varchar(255) [not null] // Budget line items in french
      egcs_ay_organizationcostcategory bigint [not null]

      indexes {
        (egcs_ay_organizationcostcategory, egcs_ay_name_en) [name: 'ay_idx_costcategorylineitemorganizationcostcategorynameen', unique, where: `_deleted = false`]
        (egcs_ay_organizationcostcategory, egcs_ay_name_fr) [name: 'ay_idx_costcategorylineitemorganizationcostcategorynamefr', unique, where: `_deleted = false`]
      }
    }
    Ref: public.agency_cost_category_line_item.egcs_ay_organizationcostcategory > public.agency_cost_category.id

    Table public.agency_fiscal_year {
      _deleted boolean [not null, default: false]
      id bigint [pk, not null, default: nextval('public.Agency_Fiscal_Year_id_seq')] // System ID
      egcs_ay_organizationagency bigint [not null]
      egcs_ay_fiscalyeardisplay varchar(9) [not null] // Display value of fiscal year, e.g. 2025-2026
      egcs_ay_fiscalyear smallint [not null] // Numerical value for fiscal year, e.g. 2026

      indexes {
        (egcs_ay_organizationagency, egcs_ay_fiscalyeardisplay) [name: 'ay_idx_fiscalyearorganizationagencyfiscalyeardisplay', unique, where: `_deleted = false`]
        (egcs_ay_organizationagency, egcs_ay_fiscalyear) [name: 'ay_idx_fiscalyearorganizationagencyfiscalyear', unique, where: `_deleted = false`]
      }
    }
    Ref: public.agency_fiscal_year.egcs_ay_organizationagency > public.agency_profile.id

    Table public.agency_address_type {
      _deleted boolean [not null, default: false]
      id bigint [pk, not null, default: nextval('public.Agency_Address_Type_id_seq')] // System ID
      egcs_ay_organizationagency bigint [not null]
      egcs_ay_typename_en varchar(255) [not null] // Address type name in english e.g Head Office
      egcs_ay_typename_fr varchar(255) [not null] // Address type name in french e.g Head Office

      indexes {
        (egcs_ay_organizationagency, egcs_ay_typename_en) [name: 'ay_idx_addresstypeorganizationagencytypenameen', unique, where: `_deleted = false`]
        (egcs_ay_organizationagency, egcs_ay_typename_fr) [name: 'ay_idx_addresstypeorganizationagencytypenamefr', unique, where: `_deleted = false`]
      }
    }
    Ref: public.agency_address_type.egcs_ay_organizationagency > public.agency_profile.id

    Table public.agency_applicant_recipient_subtype {
      _deleted boolean [not null, default: false]
      id bigint [pk, not null, default: nextval('public.Agency_Applicant_Recipient_Subtype_id_seq')] // System ID
      egcs_ay_applicantrecipienttype public.applicant_recipient_type [not null] // Type of recipient, at a minimum needs the 7 types from Open Data, more types can be added
      egcs_ay_organizationagency bigint [not null]
      egcs_ay_description_en text [not null] // Agency specific classification description in english
      egcs_ay_description_fr text [not null] // Agency specific classification description in french
      egcs_ay_name_en varchar(255) [not null] // Agency specific name for an applicant/recipient type in english (e.g. Research Institution)
      egcs_ay_name_fr varchar(255) [not null] // Agency specific name for an applicant/recipient type in french (e.g. Research Institution)

      indexes {
        (egcs_ay_organizationagency, egcs_ay_applicantrecipienttype, egcs_ay_name_en) [name: 'ay_idx_uniqueartypeen', unique, where: `_deleted = false`]
        (egcs_ay_organizationagency, egcs_ay_applicantrecipienttype, egcs_ay_name_fr) [name: 'ay_idx_uniqueartypefr', unique, where: `_deleted = false`]
      }
    }
    Ref: public.agency_applicant_recipient_subtype.egcs_ay_organizationagency > public.agency_profile.id

    Table public.agency_approval_behalf_type {
      _deleted boolean [not null, default: false]
      id bigint [pk, not null, default: nextval('public.Agency_Approval_Behalf_Type_id_seq')] // System ID
      egcs_ay_organizationagency bigint [not null]
      egcs_ay_name_en varchar(255) [not null] // Name of individual appproving on behalf of individual with authority delegation to approve
      egcs_ay_name_fr varchar(255) [not null] // Name of individual appproving on behalf of individual with authority delegation to approve - French
      egcs_ay_require_actual boolean [not null] // Indicates that the approval will require entry of additional details associated to approval if set to true (e.g. date, approver etc)

      indexes {
        (egcs_ay_organizationagency, egcs_ay_name_en) [name: 'ay_idx_approvalbehalftypeorganizationagencynameen', unique, where: `_deleted = false`]
        (egcs_ay_organizationagency, egcs_ay_name_fr) [name: 'ay_idx_approvalbehalftypeorganizationagencynamefr', unique, where: `_deleted = false`]
      }
    }
    Ref: public.agency_approval_behalf_type.egcs_ay_organizationagency > public.agency_profile.id

    Table public.agency_agreement_type {
      _deleted boolean [not null, default: false]
      id bigint [pk, not null, default: nextval('public.Agency_Agreement_Type_id_seq')]
      egcs_ay_organizationagency bigint [not null]
      egcs_ay_agreementtype public.agreement_type [not null] // Type of agreement at a minimum identified in OD, more types can be added
      egcs_ay_name_en varchar(255) [not null] // Agency specific name for an agreement type in english (e.g. Partially Repayable Contribution Agreement)
      egcs_ay_name_fr varchar(255) [not null] // Agency specific name for an agreement type in french (e.g. Partially Repayable Contribution Agreement)

      indexes {
        (egcs_ay_organizationagency, egcs_ay_agreementtype, egcs_ay_name_en) [name: 'ay_idx_agreementtypeorganizationagencyagreementtypenameen', unique, where: `_deleted = false`]
        (egcs_ay_organizationagency, egcs_ay_agreementtype, egcs_ay_name_fr) [name: 'ay_idx_agreementtypeorganizationagencyagreementtypenamefr', unique, where: `_deleted = false`]
      }
    }
    Ref: public.agency_agreement_type.egcs_ay_organizationagency > public.agency_profile.id

    Table public.transfer_payment_profile {
      _deleted boolean [not null, default: false]
      id bigint [pk, not null, default: nextval('public.Transfer_Payment_Profile_id_seq')] // System ID
      egcs_tp_agency bigint [not null]
      egcs_tp_dateend date [not null] // Effective end date of the TP Program.
      egcs_tp_datestart date [not null] // Effective start date of the TP Program
      egcs_tp_description_en text [not null] // Description of the TP program.
      egcs_tp_description_fr text [not null] // Description of the TP program.
      egcs_tp_name_en varchar(255) [not null] // English name of the TP program.
      egcs_tp_name_fr varchar(255) [not null] // French name of the TP program.
      egcs_tp_abbreviation_en varchar(255) [not null] // Short name to quickly identify the TP program.
      egcs_tp_abbreviation_fr varchar(255) [not null] // Short name to quickly identify the TP program.
      egcs_tp_tclink varchar(2000) [not null] // Link to the Terms & Conditions of the TP program.
      egcs_tp_purpose_en text [not null] // The program purpose is the program’s purpose according to the Ts&Cs.
      egcs_tp_purpose_fr text [not null] // The program purpose is the program’s purpose according to the Ts&Cs.
      egcs_tp_status public.base_status [not null]

      indexes {
        egcs_tp_name_en [name: 'tp_idx_profilenameen', where: `_deleted = false AND egcs_tp_status = 'active'`]
        egcs_tp_name_fr [name: 'tp_idx_profilenamefr', where: `_deleted = false AND egcs_tp_status = 'active'`]
        (egcs_tp_agency, egcs_tp_name_en, egcs_tp_name_fr, egcs_tp_status) [name: 'tp_idx_profileagencynameennamefrstatus', unique, where: `_deleted = false AND egcs_tp_status = 'active'`]
      }

      checks {
        `egcs_tp_dateend >= egcs_tp_datestart` [name: 'tp_chk_profiledatestartdateend']
      }
    }
    Ref: public.transfer_payment_profile.egcs_tp_agency > public.agency_profile.id

    Table public.transfer_payment_fiscal_year_budget {
      _deleted boolean [not null, default: false]
      id bigint [pk, not null, default: nextval('public.Transfer_Payment_Fiscal_Year_Budget_id_seq')] // System ID
      egcs_tp_transferpaymentprofile bigint [not null]
      egcs_tp_totalbudget numeric(19, 2) [not null] // Adjusted budget associated to the transfer payment program's budget for the fiscal year.
      egcs_tp_fiscalyear bigint [not null] // Financial year associated to the transfer payment program's budget.
      egcs_tp_overcommitthreshold numeric(5, 2) [not null] // Percentage of total budget allowed to exceed

      indexes {
        (egcs_tp_transferpaymentprofile, egcs_tp_fiscalyear) [name: 'tp_idx_fiscalyearbudgettransferpaymentprofilefiscalyear', unique, where: `_deleted = false`]
      }
    }
    Ref: public.transfer_payment_fiscal_year_budget.egcs_tp_transferpaymentprofile > public.transfer_payment_profile.id
    Ref: public.transfer_payment_fiscal_year_budget.egcs_tp_fiscalyear > public.agency_fiscal_year.id

    Table public.transfer_payment_stream {
      _deleted boolean [not null, default: false]
      id bigint [pk, not null] // #REF!
      egcs_tp_name_en varchar(255) [not null]
      egcs_tp_name_fr varchar(255) [not null]
      egcs_tp_description_en text [not null]
      egcs_tp_description_fr text [not null]
      egcs_tp_transferpaymentprofile bigint [not null]
      egcs_tp_parentstream bigint
      egcs_tp_abbreviation_en varchar(255) [not null]
      egcs_tp_abbreviation_fr varchar(255) [not null]
      egcs_tp_objective_en text [not null]
      egcs_tp_objective_fr text [not null]
      egcs_tp_allowsfurtherdistribution boolean [not null]
      egcs_tp_status public.base_status [not null]

      indexes {
        egcs_tp_name_en [name: 'tp_idx_streamnameen', where: `_deleted = false AND egcs_tp_status = 'active'`]
        egcs_tp_name_fr [name: 'tp_idx_streamnamefr', where: `_deleted = false AND egcs_tp_status = 'active'`]
        (egcs_tp_transferpaymentprofile, egcs_tp_name_en, egcs_tp_name_fr, egcs_tp_status) [name: 'tp_idx_streamtransferpaymentprofilenameennamefrstatus', unique, where: `_deleted = false AND egcs_tp_status = 'active'`]
      }
    }
    Ref: public.transfer_payment_stream.id > public.common_entity.id
    Ref: public.transfer_payment_stream.egcs_tp_transferpaymentprofile > public.transfer_payment_profile.id
    Ref: public.transfer_payment_stream.egcs_tp_parentstream > public.transfer_payment_stream.id

    Table public.transfer_payment_objective {
      _deleted boolean [not null, default: false]
      id bigint [pk, not null, default: nextval('public.Transfer_Payment_Objective_id_seq')] // System ID
      egcs_tp_transferpaymentprofile bigint [not null]
      egcs_tp_objective_en text [not null] // Program objective narrative (en)
      egcs_tp_objective_fr text [not null] // Program objective narrative (fr)

      indexes {
        (egcs_tp_transferpaymentprofile, md5(lower(egcs_tp_objective_en))) [name: 'tp_idx_objectivetransferpaymentprofileobjectiveen', unique, where: `_deleted = false`]
        (egcs_tp_transferpaymentprofile, md5(lower(egcs_tp_objective_fr))) [name: 'tp_idx_objectivetransferpaymentprofileobjectivefr', unique, where: `_deleted = false`]
      }
    }
    Ref: public.transfer_payment_objective.egcs_tp_transferpaymentprofile > public.transfer_payment_profile.id

