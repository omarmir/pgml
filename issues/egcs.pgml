    Table public.funding_case_agreement_payment {
      _deleted boolean [not null, default: false]
      id bigint [pk, not null, default: nextval('public.Funding_Case_Agreement_Payment_id_seq')] // System ID
      egcs_fc_fundingagreement bigint [not null]
      egcs_fc_isfinalforyear boolean [not null] // Is final claim for fiscal year
      egcs_fc_periodend smallint [not null] // The last month of the payment period
      egcs_fc_periodstart smallint [not null] // The first month of the payment period
      egcs_fc_paymenttype public.payment_type [not null]
      egcs_fc_comment text // An optional comment field
      egcs_fc_status public.payment_status [not null]
      egcs_fc_holdback numeric(5, 2) // The percentage of either the total agreement value or the final year fiscal year value that will be withheld until the final payment
      egcs_fc_financialsystemnumber bigint // Required on terminal status (e.g. Paid)
      egcs_fc_totalclaimstolastclaimmonth numeric(19, 2) [not null] // The total value of all processed claims for the agreement
      egcs_fc_totalforecasttolastclaimmonth numeric(19, 2) [not null] // The total forecast amount for all months up to and including the last month for which a processed claim exists
      egcs_fc_totalshortfall numeric(19, 2) [not null] // = [Total Claims to Last Claim Month] – [Total Forecast to Last Claim Month] (if the amount is negative, it is slippage, meaning it will be subtracted from the payment total; if the amount is positive, it is a shortfall, meaning the recipient did not forecast enough and it will be added to the payment total)
      egcs_fc_totalforecasttoperiodend numeric(19, 2) [not null] // The total forecast amount for all months up to and including the last month of the payment period
      egcs_fc_totalpaymentstodate numeric(19, 2) [not null] // The total value of all processed payments for the agreement
      egcs_fc_totalnextadvancepayment numeric(19, 2) [not null] // = [Total Forecast to Period End] – [Total Payments to Date] (the value of the advance payment based on the forecast before accounting for the shortfall)
      egcs_fc_previousclaimstotal numeric(19, 2) [not null] // If there are claims for the agreement that were processed outside of the system, the amount will be reflected here and added to the total claimed amount in the calculation
      egcs_fc_previouspaymentstotal numeric(19, 2) [not null] // If there are payments for the agreement that were processed outside of the system, the amount will be reflected here and added to the total paid amount in the calculation
      egcs_fc_holdbackamount numeric(19, 2) [not null] // = [Total Agreement Value] OR [Final Year Fiscal Value] * [Holdback %]
      egcs_fc_availablefordisbursement numeric(19, 2) [not null] // = [Total Claimed] + [Total Forecast for Unclaimed Months in Current FY] + [Total FY Value of Future Fiscal Years] – [Total Payments] – [Holdback Amount] (i.e. the amount of money that can be paid before the Holdback threshold is reached)
      egcs_fc_payeavailablefordisbursement numeric(19, 2) [not null] // For PAYE payments, this is the total amount of unpaid money remaining in the PAYE commitment
      egcs_fc_paye2availablefordisbursement numeric(19, 2) [not null] // For PAYE2 payments, this is the total amount of unpaid money remaining on the PAYE2 commitment line
      egcs_fc_previousyearpayeavailablefordisbursement numeric(19, 2) [not null] // For previous-year PAYE payments (i.e. PAYEs for a fiscal year that is two years ago or earlier), this is the total amount of unpaid money remaining in the PYP commitment
      egcs_fc_commitmentavailablefordisbursement numeric(19, 2) [not null] // For standard payments, this is the total amount of unpaid money remaining on the commitment line(s) for the current fiscal year
      egcs_fc_totalsystemcalculatedamount numeric(19, 2) [not null] /*
    For reimbursements, = [Total Claims to Last Claim Month] minus [Total Payments to Date]
     For advances, = [Total Shortfall] + [Total Next Advance Payment]
      */
      egcs_fc_holdbackrelease numeric(19, 2) [not null] // The amount of the holdback that is being released as part of the payment, either because it is the final payment or the Release Holdback manual override is engaged
      egcs_fc_paymentamount numeric(19, 2) [not null] /*
    The total payment amount. It is equal to the lower of:

     Available for Disbursement (except for the final payment or payments where the Release Holdback manual override is engaged)
     PAYE Available for Disbursement (PAYE payments only)
     PAYE2 Available for Disbursement (PAYE2 payments only)
     PYP Available for Disbursement (PYP payments only)
     Commit. Available for Disbursement (standard payments only)
     Total System Calculated Amount
      */

      indexes {
        egcs_fc_fundingagreement [name: 'fc_idx_paymentfundingagreement', where: `_deleted = false`]
      }
    }
    Ref: public.funding_case_agreement_payment.egcs_fc_fundingagreement > public.funding_case_agreement_profile.id

