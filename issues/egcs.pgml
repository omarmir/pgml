      egcs_cn_scopetype public.entity_type [not null] // fundingopportunity | transferpaymentstream | fundingcaseintake | fundingcaseagreement | applicantrecipient
      egcs_cn_scopeid bigint [not null] // Which specific TP Stream or FO owns this config
      egcs_cn_entitytype public.entity_type [not null] // What completion event triggers set creation
      egcs_cn_oncompletion boolean [not null] // Is this set generated automatically on completion?
      egcs_cn_name_en varchar(255) [not null]
      egcs_cn_name_fr varchar(255) [not null]
      egcs_cn_order smallint [not null]
      egcs_cn_sequential boolean [not null] // Are reviews created and completed sequentially?
      egcs_cn_approvaltemplate bigint
      egcs_cn_active boolean [not null]

      indexes {
        (egcs_cn_scopeid, egcs_cn_entitytype, egcs_cn_name_en) [name: 'cn_idx_reviewsetsetupscopeidentitytypenameen', unique, where: `_deleted = false AND egcs_cn_active = TRUE`]
        (egcs_cn_scopeid, egcs_cn_entitytype, egcs_cn_name_fr) [name: 'cn_idx_reviewsetsetupscopeidentitytypenamefr', unique, where: `_deleted = false AND egcs_cn_active = TRUE`]
        (egcs_cn_scopeid, egcs_cn_entitytype, egcs_cn_order) [name: 'cn_idx_reviewsetsetupscopeidentitytypeorder', unique, where: `_deleted = false AND egcs_cn_active = TRUE`]
        (id, egcs_cn_entitytype) [name: 'cn_idx_reviewsetsetupidentitytype', unique]
      }

      checks {
        `egcs_cn_entitytype NOT IN ('fundingopportunity', 'transferpaymentstream', 'commonreview', 'commonrecommendation')` [name: 'cn_chk_reviewsetsetupentitytype']
        `egcs_cn_scopetype IN ('fundingopportunity', 'transferpaymentstream', 'fundingcaseintake', 'fundingcaseagreement', 'applicantrecipient')` [name: 'cn_chk_reviewsetsetupscopetype']
      }
    }
