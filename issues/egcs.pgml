    Table public.common_approval {
      id bigint [pk, not null, default: nextval('public.Common_Approval_id_seq')] // System ID
      egcs_cn_sequence numeric [not null]
      egcs_cn_name_en varchar(255) [not null]
      egcs_cn_name_fr varchar(255) [not null]
      egcs_cn_routingslip bigint [not null]
      egcs_cn_defaultuser bigint [not null] // The user assigned from the approval template
      egcs_cn_assigneduser bigint // The user the approval is assigned to and the person that can action this approval
      egcs_cn_onbehalf bigint // Required if the default user != assigned user
      egcs_cn_approvalpositiontitle text
      egcs_cn_isadded boolean [not null]
      egcs_cn_approvalvalue boolean
      egcs_cn_approvaldate timestamptz
      egcs_cn_comment text
      egcs_cn_attachment bigint

      indexes {
        (egcs_cn_routingslip, egcs_cn_sequence) [name: 'cn_idx_approvalroutingslipsequence', unique]
      }

      checks {
        `NOT (egcs_cn_approvalpositiontitle IS NULL AND egcs_cn_approvalvalue IS NOT NULL)` [name: 'cn_chk_approvalapprovalvalueapprovalpositiontitlenull']
        `NOT (egcs_cn_defaultuser <> egcs_cn_assigneduser AND egcs_cn_onbehalf IS NULL)` [name: 'cn_chk_approvaldefaultuserassigneduseronbehalfnull']
        `NOT (egcs_cn_defaultuser = egcs_cn_assigneduser AND egcs_cn_onbehalf IS NOT NULL)` [name: 'cn_chk_approvalassigneduseronbehalfapprovalpositiontitlenotnull']
      }
    }
