        Constraint cn_chk_additionalreviewersentitytype: egcs_cn_entitytype <> ALL (ARRAY['fundingopportunity'::public."Entity_Type", 'fundingcaseintake'::public."Entity_Type", 'fundingcaseagreement'::public."Entity_Type", 'applicantrecipient'::public."Entity_Type", 'transferpaymentstream'::public."Entity_Type"])
