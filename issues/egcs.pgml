    Ref cn_ref_reviewsetupreviewsetentitytype: public.common_review_setup.(egcs_cn_reviewset, egcs_cn_entitytype) > public.common_review_set_setup.(id, egcs_cn_entitytype)

    Table public.common_review_set {
      _deleted boolean [not null, default: false]
      id bigint [pk, not null, default: nextval('public.Common_Review_Set_id_seq')] // System ID
      egcs_cn_status public.statuses [not null]
      egcs_cn_reviewsetsetup bigint [not null]
      egcs_cn_approvaltemplate bigint
      egcs_cn_entitytype public.entity_type [not null]
      egcs_cn_entityid bigint [not null]

      indexes {
        (egcs_cn_reviewsetsetup, egcs_cn_entitytype, egcs_cn_entityid, egcs_cn_status) [name: 'cn_idx_reviewsetreviewsetsetupentitytypeentityidstatus', unique, where: `(_deleted = false)
      AND (
        egcs_cn_status <> ALL (
          ARRAY[
            'complete'::public.statuses,
            'approved'::public.statuses,
            'denied'::public.statuses,
            'withdrawn'::public.statuses,
            'cancelled'::public.statuses
          ]
        )
      )`]
      }
    }
    Ref: public.common_review_set.egcs_cn_reviewsetsetup > public.common_review_set_setup.id
    Ref: public.common_review_set.egcs_cn_approvaltemplate > public.common_approval_template.id
    Ref cn_ref_reviewsetentityidentitytype: public.common_review_set.(egcs_cn_entityid, egcs_cn_entitytype) > public.common_entity.(id, egcs_cn_entitytype)

    Table public.common_review {
      _deleted boolean [not null, default: false]
      id bigint [pk, not null, default: nextval('public.Common_Review_id_seq')] // System ID
      egcs_cn_helpers jsonb // key-value pairs
      egcs_cn_status public.statuses [not null]
      egcs_cn_disablecustomoutcomes boolean [not null]
      egcs_cn_disablealignment boolean [not null]
      egcs_cn_disablereviewers boolean [not null]
      egcs_cn_reviewalignment boolean
      egcs_cn_reviewalignmentnarrative text
      egcs_cn_reviewalignresult numeric(10, 2)
      egcs_cn_reviewresult numeric(10, 2) [not null]
      egcs_cn_reviewset bigint [not null]
      egcs_cn_reviewschema bigint [not null]
      egcs_cn_approvaltemplate bigint

      indexes {
        egcs_cn_reviewset [name: 'cn_idx_reviewreviewset']
      }

      checks {
        `NOT (egcs_cn_reviewalignment = TRUE AND (egcs_cn_reviewalignmentnarrative IS NULL OR egcs_cn_reviewalignresult IS NULL))` [name: 'cn_chk_reviewreviewresult']
      }
    }
    Ref: public.common_review.egcs_cn_reviewset > public.common_review_set.id
    Ref: public.common_review.egcs_cn_reviewschema > public.common_review_schema.id
    Ref: public.common_review.egcs_cn_approvaltemplate > public.common_approval_template.id

    Table public.common_review_response {
      id bigint [pk, not null, default: nextval('public.Common_Review_Response_id_seq')] // System ID
      egcs_cn_section varchar(255) [not null]
      egcs_cn_subsection varchar(255) [not null]
      egcs_cn_question varchar(255) [not null]
      egcs_cn_value numeric(10, 2)
      egcs_cn_calculated boolean [not null]
      egcs_cn_comment text [not null]
      egcs_cn_assessment bigint [not null]

      indexes {
        (egcs_cn_assessment, egcs_cn_section, egcs_cn_subsection, egcs_cn_question) [name: 'cn_idx_reviewresponseassessmentsectionsubsectionquestion', unique]
      }
    }
    Ref: public.common_review_response.egcs_cn_assessment > public.common_review.id

