    Table public.applicant_recipient_funding_history {
      _deleted boolean [not null, default: false]
      id bigint [pk, not null, default: nextval('public.Applicant_Recipient_Funding_History_id_seq')] // System ID
      egcs_ar_applicantrecipient bigint [not null]
      egcs_ar_fundingagreement bigint
      egcs_ar_agreementnumber varchar(255) // The unique identifying number assigned to the Grants and Contributions (Gs&Cs) Funding Agreement.
      egcs_ar_description text // A detailed summary or narrative description of the approved project
      egcs_ar_agreementtitle_en varchar(255) // The official title of the funding agreement in English
      egcs_ar_agreementtitle_fr varchar(255) // The official title of the funding agreement in French
      egcs_ar_program varchar(255) // The specific name of the Grants and Contributions (Gs&Cs) program under which the funding was provided.
      egcs_ar_startdate date // The date on which the funding agreement activities officially commence.
      egcs_ar_enddate date // The final date by which all activities under the funding agreement must be completed.
      egcs_ar_funder smallint /*
    The government department or agency responsible for administering and extending the funding.
    See annex A of the Open Data dictionary for Gs&Cs for list of department numbers
      */
      egcs_ar_fundingamount numeric(19, 2) // Total approved funding amount for the agreement.

      indexes {
        (egcs_ar_funder, egcs_ar_agreementnumber, egcs_ar_applicantrecipient, egcs_ar_program) [name: 'ar_idx_fundinghistoryfunderagreementnumberprogram', unique, where: `_deleted = false`]
        (egcs_ar_applicantrecipient, egcs_ar_fundingagreement, egcs_ar_program, egcs_ar_agreementnumber) [name: 'ar_idx_fundinghistoryfundingagreementprogramagreementnumber', unique, where: `_deleted = false AND egcs_ar_fundingagreement IS NOT NULL`]
      }

      checks {
        `NOT (
            (egcs_ar_fundingagreement IS NULL)
            AND (egcs_ar_agreementnumber IS NULL OR egcs_ar_description IS NULL OR egcs_ar_agreementtitle_en IS NULL OR egcs_ar_agreementtitle_fr IS NULL OR egcs_ar_program IS NULL OR egcs_ar_startdate IS NULL OR egcs_ar_enddate IS NULL OR egcs_ar_funder IS NULL OR egcs_ar_fundingamount  IS NULL)
        )` [name: 'ar_chk_applicantrecipientprofile_required_if_egcs_ar_fundingagreement_null']
        `NOT (
            (egcs_ar_fundingagreement IS NOT NULL)
            AND (egcs_ar_agreementnumber IS NOT NULL OR egcs_ar_description IS NOT NULL OR egcs_ar_agreementtitle_en IS NOT NULL OR egcs_ar_agreementtitle_fr IS NOT NULL OR egcs_ar_program IS NOT NULL OR egcs_ar_startdate IS NOT NULL OR egcs_ar_enddate IS NOT NULL OR egcs_ar_funder IS NOT NULL OR egcs_ar_fundingamount  IS NOT NULL)
        )` [name: 'ar_chk_applicantrecipientprofile_null_if_egcs_ar_fundingagreement']
      }
    }
    Ref: public.applicant_recipient_funding_history.egcs_ar_applicantrecipient > public.applicant_recipient_profile.id
    Ref: public.applicant_recipient_funding_history.egcs_ar_fundingagreement > public.funding_case_agreement_profile.id
    Ref: public.applicant_recipient_funding_history.egcs_ar_funder > public.common_gwcoa.egcs_cn_number

