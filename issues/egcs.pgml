      egcs_tp_transferpaymentbudget bigint [not null] // Financial year associated to the transfer payment program's budget.
      egcs_tp_overcommitthreshold numeric(5, 2) [not null] // Percentage of total budget allowed to exceed

      indexes {
        (egcs_tp_transferpaymentstream, egcs_tp_transferpaymentbudget) [name: 'tp_idx_streambudgettransferpaymentstreamtransferpaymentbudget', unique, where: `_deleted = false`]
